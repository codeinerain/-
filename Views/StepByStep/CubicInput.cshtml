@{
    ViewData["Title"] = "Кубические уравнения - пошаговое решение";
}

<h2 class="text-center mb-4">Кубические уравнения (3 степень)</h2>
<p class="text-center mb-4">Уравнение вида: \(ax^3 + bx^2 + cx + d = 0\)</p>

<div class="card p-4 mx-auto" style="max-width: 500px;">
    <h4 class="text-center">Введите коэффициенты:</h4>

    <form method="post" asp-action="CubicStart">
        <div class="mb-3">
            <label class="form-label">a (коэффициент при x³)</label>
            <input type="number" name="a" class="form-control" step="any" required />
            <small class="text-muted">a ≠ 0</small>
        </div>

        <div class="mb-3">
            <label class="form-label">b (коэффициент при x²)</label>
            <input type="number" name="b" class="form-control" step="any" required />
        </div>

        <div class="mb-3">
            <label class="form-label">c (коэффициент при x)</label>
            <input type="number" name="c" class="form-control" step="any" required />
        </div>

        <div class="mb-3">
            <label class="form-label">d (свободный член)</label>
            <input type="number" name="d" class="form-control" step="any" required />
        </div>

        <button type="submit" class="btn btn-primary w-100">Начать решение</button>
    </form>
</div>

<div class="text-center mt-4">
    <a asp-controller="StepByStep" asp-action="Index" class="btn btn-secondary">Назад</a>
</div>