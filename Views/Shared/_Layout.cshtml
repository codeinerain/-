<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Тренажёр уравнений</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Название сайта по центру вверху */
        .site-title {
            position: fixed;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1030;
            font-size: 24px;
            font-weight: bold;
        }

        /* Блок навигации слева вверху */
        .side-nav {
            position: fixed;
            top: 60px;
            left: 10px;
            z-index: 1020;
            background-color: rgba(255,255,255,0.9);
            padding: 10px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        /* Центрируем содержимое страницы  */
        .main-centered {
            align-items: center;
            justify-content: center;
            margin-top: 80px;
            padding: 20px;
            width: 100%;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
        }
    </style>
</head>
<body>
     @* название сайта показывается, когда пользователь не в блоке теории или практики *@
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var hideTitle = controller == "Theory" || controller == "Practice";
    }

    @if (!hideTitle)
    {
        <div class="site-title">Тренажёр уравнений</div>
    }

  @*  блоки меню, которые слева сверху *@
    <div class="side-nav">
        <ul class="nav flex-column">
            @if (User.Identity.IsAuthenticated)
            {
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Главная</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">Выход</a>
                </li>
            }
        </ul>
    </div>

    <div class="container">
        <main role="main" class="main-centered">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" id="MathJax-script" async></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>